# Reminders cron secret (must match Authorization header in Cloud Scheduler)
CRON_SECRET=

# Admin sessions
SESSION_SECRET=

# Google Calendar
GOOGLE_CALENDAR_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
