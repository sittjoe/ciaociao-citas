rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ============================================
    // SLOTS: Horarios disponibles
    // ============================================
    match /slots/{slotId} {
      // Lectura pública solo de slots disponibles
      allow read: if resource == null || resource.data.available == true;

      // Solo admin autenticado puede crear, actualizar y eliminar slots
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll(['datetime', 'available', 'createdAt'])
                    && request.resource.data.available is bool
                    && request.resource.data.datetime is timestamp;

      allow update: if isAdmin()
                    && request.resource.data.keys().hasAll(['datetime', 'available'])
                    && request.resource.data.available is bool
                    && request.resource.data.datetime is timestamp;

      allow delete: if isAdmin();
    }

    // ============================================
    // APPOINTMENTS: Citas de clientes
    // ============================================
    match /appointments/{appointmentId} {
      // Clientes pueden crear citas con status 'pending' sin autenticación
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['name', 'email', 'phone', 'slotId', 'slotDatetime', 'identificationUrl', 'status', 'createdAt'])
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.phone is string
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 3
                    && request.resource.data.name.size() <= 100;

      // Solo admin autenticado puede leer, actualizar y eliminar citas
      allow read:   if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.status in ['pending', 'accepted', 'rejected', 'cancelled'];
      allow delete: if isAdmin();
    }

    // ============================================
    // LOGIN ATTEMPTS: Protección rate-limit (solo Cloud Functions via Admin SDK)
    // ============================================
    match /loginAttempts/{ip} {
      allow read, write: if false;
    }

    // ============================================
    // AUDIT LOG: Solo Cloud Functions via Admin SDK
    // ============================================
    match /auditLog/{logId} {
      allow read, write: if false;
    }
  }
}
