rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ============================================
    // SLOTS: Horarios disponibles
    // ============================================
    match /slots/{slotId} {
      // Lectura pública solo de slots disponibles
      allow read: if resource == null || resource.data.available == true;

      // Solo admin autenticado puede crear, actualizar y eliminar slots
      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll(['datetime', 'available', 'createdAt'])
                    && request.resource.data.available is bool
                    && request.resource.data.datetime is timestamp;

      allow update: if isAdmin()
                    && request.resource.data.keys().hasAll(['datetime', 'available'])
                    && request.resource.data.available is bool
                    && request.resource.data.datetime is timestamp;

      allow delete: if isAdmin();
    }

    // ============================================
    // APPOINTMENTS: Citas de clientes
    // ============================================
    match /appointments/{appointmentId} {
      // Las reservas públicas deben pasar por /api/booking para preservar
      // validación, rate limit, uploads server-side y transacciones de slot.
      allow create: if false;

      // Solo admin autenticado puede leer, actualizar y eliminar citas
      allow read:   if isAdmin();
      allow update: if isAdmin()
                    && request.resource.data.status in ['pending', 'accepted', 'rejected', 'cancelled'];
      allow delete: if isAdmin();
    }

    // ============================================
    // GUESTS: Invitados de citas (subcolección)
    // ============================================
    match /appointments/{appointmentId}/guests/{guestId} {
      // All writes go through Admin SDK (server-side), which bypasses these rules.
      allow write: if false;
      // Only authenticated admins can read guest data (contains PII + ID URLs)
      allow read: if isAdmin();
    }

    // ============================================
    // LOGIN ATTEMPTS: Protección rate-limit (solo Cloud Functions via Admin SDK)
    // ============================================
    match /loginAttempts/{ip} {
      allow read, write: if false;
    }

    // ============================================
    // AUDIT LOG: Solo Cloud Functions via Admin SDK
    // ============================================
    match /auditLog/{logId} {
      allow read, write: if false;
    }

    // Internal server-side concurrency guard for one active appointment per datetime.
    match /slotDatetimeLocks/{lockId} {
      allow read, write: if false;
    }

    match /bookingIdempotency/{requestId} {
      allow read, write: if false;
    }

    match /emailOutbox/{emailId} {
      allow read, write: if false;
    }

    match /maintenanceRuns/{runId} {
      allow read, write: if false;
    }
  }
}
