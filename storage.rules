rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ============================================
    // IDENTIFICATIONS: Archivos de identificación de clientes
    // ============================================
    match /identifications/{fileName} {
      // Writes go through Admin SDK (server-side) which bypasses these rules.
      // Deny all client-side writes to prevent anonymous spam uploads.
      allow write: if false;

      // Solo admin autenticado puede leer identificaciones (PII protegida)
      allow read: if isAdmin();
    }

    // ============================================
    // TODOS LOS DEMÁS ARCHIVOS: Bloqueados por defecto
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
