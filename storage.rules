rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ============================================
    // IDENTIFICATIONS: Archivos de identificación de clientes
    // ============================================
    match /identifications/{fileName} {
      // Clientes pueden subir archivos sin autenticación (se requiere durante el booking)
      // Límite: 5MB, solo imágenes y PDF
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                   || request.resource.contentType == 'application/pdf');

      // Solo admin autenticado puede leer identificaciones (PII protegida)
      allow read: if isAdmin();
    }

    // ============================================
    // TODOS LOS DEMÁS ARCHIVOS: Bloqueados por defecto
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
